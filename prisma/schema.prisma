// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  Owner
  BidManager
  Presales
  Finance
  DocController
  Reviewer
}

model Organization {
  id                  String               @id @default(uuid())
  name                String
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  users               User[]
  clientCompanies     ClientCompany[]
  tenders             Tender[]
  auditEvents         AuditEvent[]
  clientDocuments     ClientDocument[]
  complianceMatrices  ComplianceMatrix[]
  complianceItems     ComplianceItem[]
  tenderRequirements  TenderRequirement[]
  evidenceLinks       EvidenceLink[]
  tasks               Task[]
  submissionPacks     SubmissionPack[]
  // P11 — PDPL surface
  consentEvents       ConsentEvent[]
  dataSubjectRequests DataSubjectRequest[]
  tenderAccesses      TenderAccess[]
  retentionActions    RetentionAction[]
  // P12b — ingestion
  ingestionJobs       IngestionJob[]
  // P12c — DPO contact (one row per org via @@unique on DpoContact.organizationId)
  dpoContact          DpoContact?
  // P14 — LLM provider usage / cost ledger
  llmUsageLogs        LlmUsageLog[]
  // P15 — DPO training register
  trainingRecords     DpoTrainingRecord[]
  // P18 — inbound email transport
  inboundEmails       InboundEmail[]
  // P19 — outbound webhooks
  webhookSubscriptions WebhookSubscription[]
  webhookDeliveries    WebhookDelivery[]
  // P21 — billing
  subscription        Subscription?
  usageCounters       UsageCounter[]
}

model User {
  id             String         @id @default(uuid())
  email          String         @unique
  name           String
  password       String?
  role           UserRole
  organizationId String
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  auditEvents    AuditEvent[]
  tenderAccesses TenderAccess[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model ClientCompany {
  id             String           @id @default(uuid())
  name           String
  organizationId String
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  tenders        Tender[]
  documents      ClientDocument[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
}

model Tender {
  id              String              @id @default(uuid())
  title           String
  organizationId  String
  organization    Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  clientCompanyId String
  clientCompany   ClientCompany       @relation(fields: [clientCompanyId], references: [id], onDelete: Cascade)
  source          String              @default("manual")
  status          String              @default("intake")
  matrices        ComplianceMatrix[]
  requirements    TenderRequirement[]
  tasks           Task[]
  submissionPacks SubmissionPack[]
  accesses        TenderAccess[]
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
}

// Re-parented to ClientCompany (PRD ERD §3 fix). Documents are reusable
// across multiple tenders for the same client; per-tender binding lives
// in EvidenceLink against ComplianceItem. Blob lives in the object
// store; the row carries `storageKey` + `contentType` + `sizeBytes`
// when an actual file is uploaded (nullable so legacy
// register-by-filename rows stay valid).
model ClientDocument {
  id              String         @id @default(uuid())
  filename        String
  clientCompanyId String
  clientCompany   ClientCompany  @relation(fields: [clientCompanyId], references: [id], onDelete: Cascade)
  organizationId  String
  organization    Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  documentType    String         @default("other")
  sensitivity     String         @default("low")
  state           String         @default("active")
  expiresAt       DateTime?
  storageKey      String?
  contentType     String?
  sizeBytes       Int?
  evidenceLinks   EvidenceLink[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([organizationId])
  @@index([clientCompanyId])
}

// PDPL: audit must survive user erasure. userId is nullable + SetNull
// so erasing a User pseudonymises the audit row instead of removing it.
model AuditEvent {
  id             String       @id @default(uuid())
  action         String
  entityType     String
  entityId       String
  userId         String?
  user           User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  timestamp      DateTime     @default(now())
  details        Json?

  @@index([organizationId])
  @@index([entityType, entityId])
  @@index([userId])
}

// Versioned compliance matrix per tender. (tenderId, version) is unique.
// Items are children; an Item ties to one or more ClientDocuments via EvidenceLink.
model ComplianceMatrix {
  id             String           @id @default(uuid())
  tenderId       String
  tender         Tender           @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  version        Int
  status         String           @default("draft")
  generatedAt    DateTime         @default(now())
  items          ComplianceItem[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@unique([tenderId, version])
  @@index([organizationId])
  @@index([tenderId])
}

model ComplianceItem {
  id              String           @id @default(uuid())
  matrixId        String
  matrix          ComplianceMatrix @relation(fields: [matrixId], references: [id], onDelete: Cascade)
  organizationId  String
  organization    Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  requirementId   String
  requirementText String
  category        String
  owner           String
  risk            String
  status          String
  dueDate         DateTime?
  evidenceLinks   EvidenceLink[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([organizationId])
  @@index([matrixId])
}

model TenderRequirement {
  id             String       @id @default(uuid())
  tenderId       String
  tender         Tender       @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  category       String
  text           String
  risk           String       @default("medium")
  owner          String?
  source         String       @default("manual")
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId])
  @@index([tenderId])
}

// Many-to-many between ComplianceItem and ClientDocument. Allows the
// same document to be reused as evidence across many tenders' items.
model EvidenceLink {
  id               String         @id @default(uuid())
  organizationId   String
  organization     Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  complianceItemId String
  complianceItem   ComplianceItem @relation(fields: [complianceItemId], references: [id], onDelete: Cascade)
  documentId       String
  document         ClientDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  note             String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@unique([complianceItemId, documentId])
  @@index([organizationId])
  @@index([documentId])
}

// Persisted remediation tasks derived from compliance items (or created
// manually). Service wiring is P10.1; the model is added now so the
// schema is consistent with the PRD.
model Task {
  id              String       @id @default(uuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  tenderId        String
  tender          Tender       @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  title           String
  description     String?
  owner           String?
  status          String       @default("open")
  priority        String       @default("medium")
  dueDate         DateTime?
  derivedFromItem String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([organizationId])
  @@index([tenderId])
}

// Persisted submission pack handle (manifest hash + version + audit).
// Service wiring is P10.1.
model SubmissionPack {
  id              String       @id @default(uuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  tenderId        String
  tender          Tender       @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  version         Int
  status          String       @default("draft")
  manifestSha256  String
  itemCount       Int
  overrideAudit   Json?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@unique([tenderId, version])
  @@index([organizationId])
}

// =================================================================
// P11 — PDPL surface
// =================================================================

// Consent ledger. Records every grant/withdraw event for a (subject,
// purpose) pair. The current state is the most-recent event. Subjects
// are addressed by email (PDPL Art. 4 — natural person identifier);
// `subjectUserId` is only set when the subject has an account.
model ConsentEvent {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  subjectEmail   String
  subjectUserId  String?
  purpose        String       // 'whatsapp_reminders' | 'data_processing' | ...
  state          String       // 'granted' | 'withdrawn'
  source         String       @default("api")
  recordedBy     String?      // user id of admin recording, null for self-service
  details        Json?
  recordedAt     DateTime     @default(now())
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId])
  @@index([subjectEmail])
  @@index([purpose])
}

// PDPL data-subject rights workflow (Art. 12–17).
// type ∈ access | erasure | rectification. Each request goes through
// pending → approved/denied. Access requests are completed by
// attaching a snapshot to `payload`. Erasure is executed asynchronously
// by an admin (no auto-erasure to avoid accidental data loss).
model DataSubjectRequest {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  type           String       // 'access' | 'erasure' | 'rectification'
  subjectEmail   String
  status         String       @default("pending") // pending|approved|denied|completed
  requestedBy    String?
  requestedAt    DateTime     @default(now())
  decidedBy      String?
  decidedAt      DateTime?
  completedAt    DateTime?
  notes          String?
  payload        Json?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId])
  @@index([subjectEmail])
  @@index([status])
}

// Per-tender access list. The org-wide UserRole still applies; this
// adds finer-grained "who can see/edit which tenders" on top. Roles:
// Owner | Editor | Reviewer | Viewer. The (userId, tenderId) pair is
// unique so a user has at most one role per tender.
model TenderAccess {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenderId       String
  tender         Tender       @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  role           String       // 'Owner' | 'Editor' | 'Reviewer' | 'Viewer'
  grantedBy      String?
  grantedAt      DateTime     @default(now())
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([userId, tenderId])
  @@index([organizationId])
  @@index([tenderId])
}

// P12c — DPO contact registry. Stores the tenant's Data Protection
// Officer contact details + SDAIA authority recipient for the 72h
// breach-notification flow. One row per organization.
model DpoContact {
  id                  String       @id @default(uuid())
  organizationId      String       @unique
  organization        Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name                String
  email               String
  phone               String?
  authorityEmail      String       // SDAIA recipient for breach notifications
  retentionPolicyDays Int          @default(2555) // ~7 years default
  updatedBy           String?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
}

// P12b — Worker queue: the API enqueues by inserting rows; the Python
// worker polls + atomically claims them. DB-backed rather than a
// managed broker so the system stays portable across local/cloud.
model IngestionJob {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  kind           String       // 'etimad' | 'upload' | 'email' | 'link'
  status         String       @default("pending") // pending | processing | completed | failed
  payload        Json
  result         Json?
  errorMessage   String?
  attempts       Int          @default(0)
  claimedBy      String?
  claimedAt      DateTime?
  completedAt    DateTime?
  createdBy      String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId])
  @@index([status])
  @@index([kind, status])
}

// Audit-trailed destruction request lifecycle. Replaces the in-memory
// `RetentionService.requests` map. Approver MUST differ from requestor
// (separation of duties), enforced at the service layer.
model RetentionAction {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  documentId     String       // ClientDocument id (no FK so audit survives doc delete)
  action         String       // 'destroy' | 'archive'
  reason         String
  requestedBy    String
  requestedAt    DateTime     @default(now())
  status         String       @default("pending") // pending|approved|denied|executed
  decidedBy      String?
  decidedAt      DateTime?
  executedAt     DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId])
  @@index([documentId])
  @@index([status])
}

// P14 — LLM usage ledger. One row per LLM call. Used by BudgetGuard to
// enforce daily request + cost caps and by ops to audit spend. Tenant-
// scoped via organizationId. No prompt/response text stored — we keep
// the surface narrow (cost telemetry only, not a content log).
model LlmUsageLog {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  tenderId       String?      // optional linkage to a tender
  provider       String       // 'deepseek' | 'ollama' | 'mock'
  model          String
  promptVersion  String?
  jobType        String?      // 'tender_enrichment' | 'requirement_extract' | ...
  inputTokens    Int?
  outputTokens   Int?
  totalTokens    Int?
  estimatedCost  Decimal?     @db.Decimal(12, 6)
  status         String       @default("ok") // ok | error | budget_blocked
  errorMessage   String?
  createdAt      DateTime     @default(now())

  @@index([organizationId])
  @@index([organizationId, createdAt])
  @@index([provider])
}

// P15 — DPO training register. Captures evidence that staff who
// handle personal data have completed PDPL-relevant training. The
// subject is either a platform User (userId set) or a snapshot of an
// external staff member (subjectName/Email always present, even when
// userId is set — so the row survives a User row erasure).
model DpoTrainingRecord {
  id                  String       @id @default(uuid())
  organizationId      String
  organization        Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  // Optional link to a platform User. No FK so erasure of the User
  // doesn't cascade-delete the training evidence — the snapshot
  // fields below remain.
  userId              String?
  subjectName         String
  subjectEmail        String
  topic               String       // e.g. 'PDPL Awareness', 'Customer Data Handling'
  provider            String?      // 'internal' | vendor name
  completedAt         DateTime
  validUntil          DateTime?    // null = no expiry tracked
  evidenceRef         String?      // free-text reference (URL, cert id, file name)
  evidenceDocumentId  String?      // optional ClientDocument linkage
  notes               String?
  recordedBy          String       // User id who entered the record
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  @@index([organizationId])
  @@index([organizationId, validUntil])
  @@index([organizationId, subjectEmail])
}

// P18 — Inbound-email transport. One row per webhook delivery from
// an inbound provider (Mailgun/Postmark/etc). messageId is globally
// unique for idempotency — re-delivery of the same Message-Id is a
// no-op. organizationId is nullable because we may receive mail
// that's mis-routed (status='rejected') before we know the tenant.
model InboundEmail {
  id               String        @id @default(uuid())
  messageId        String        @unique
  organizationId   String?
  organization     Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  fromAddress      String
  toAddress        String
  subject          String?
  body             String        // plain-text body, truncated by service
  status           String        // 'routed' | 'unrouted' | 'rejected'
  routedAction     String?       // e.g. 'data_subject.access.requested'
  routedEntityType String?
  routedEntityId   String?
  rejectionReason  String?
  receivedAt       DateTime      @default(now())
  createdAt        DateTime      @default(now())

  @@index([organizationId])
  @@index([status])
  @@index([receivedAt])
}

// P19 — Outbound webhook subscriptions. One row per (orgId, url)
// pair. `secret` is the HMAC signing key; it is NEVER returned in
// API responses after the create/rotate call.
model WebhookSubscription {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  url            String
  secret         String       // raw HMAC key; never returned post-create
  eventTypes     String[]     // ['ticket.created', 'document.expired', ...]
  active         Boolean      @default(true)
  description    String?
  createdBy      String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deliveries     WebhookDelivery[]

  @@index([organizationId])
  @@index([organizationId, active])
}

// One row per dispatch attempt. status='pending' | 'delivered' |
// 'failed'. attempts increments on retry; lastError captures the
// most recent failure for ops triage.
model WebhookDelivery {
  id             String              @id @default(uuid())
  subscriptionId String
  subscription   WebhookSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  eventType      String
  payload        Json
  status         String              @default("pending")
  attempts       Int                 @default(0)
  lastError      String?
  responseStatus Int?
  lastTriedAt    DateTime?
  deliveredAt    DateTime?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@index([organizationId])
  @@index([subscriptionId])
  @@index([status])
  @@index([createdAt])
}

// P21 — Billing. The plan catalog is defined in code (PLAN_CATALOG)
// so plan-rule changes ship via deploy, not via a DB write surface.
// One Subscription per org (orgId UNIQUE). status mirrors Stripe.
model Subscription {
  id                   String       @id @default(uuid())
  organizationId       String       @unique
  organization         Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  planCode             String       @default("free") // 'free' | 'basic' | 'pro'
  status               String       @default("active") // 'active' | 'past_due' | 'canceled' | 'incomplete'
  stripeCustomerId     String?
  stripeSubscriptionId String?      @unique
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean      @default(false)
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  @@index([planCode])
  @@index([status])
}

// Per-day per-metric counter. Wide enough to cover any future metric
// (llm_requests, llm_tokens, documents_created, webhook_events, ...).
// (orgId, date, metric) is unique so callers `upsert` to bump.
model UsageCounter {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  date           DateTime     // UTC midnight of the day
  metric         String       // canonical metric name (snake_case)
  count          BigInt       @default(0)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([organizationId, date, metric])
  @@index([organizationId, date])
  @@index([metric])
}
