# BidReady KSA — local development defaults.
# Copy to .env for local runs. These are NON-SECRET dev-only values.
# Never use these values outside local development.

# ============================================================
# Core
# ============================================================
NODE_ENV=development
API_PORT=8080
# At least 32 chars in production; dev placeholder is fine locally.
JWT_SECRET=dev_jwt_secret_change_me_at_least_32_chars

# ============================================================
# PostgreSQL (docker-compose: postgres)
# ============================================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=bidready
POSTGRES_USER=bidready
POSTGRES_PASSWORD=bidready_dev_pw
DATABASE_URL=postgresql://bidready:bidready_dev_pw@localhost:5432/bidready

# ============================================================
# Queue (docker-compose: redis)
#   QUEUE_PROVIDER=memory  — default; in-process, no Redis needed
#   QUEUE_PROVIDER=bullmq  — uses Redis (compose-provided)
# ============================================================
QUEUE_PROVIDER=memory
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0
BULLMQ_PREFIX=bidready

# ============================================================
# Object storage (docker-compose: minio; S3-compatible)
# Migrates to AWS S3 by pointing at s3.<region>.amazonaws.com.
# ============================================================
OBJECT_STORE_ENDPOINT=localhost
OBJECT_STORE_PORT=9000
OBJECT_STORE_USE_SSL=false
OBJECT_STORE_ACCESS_KEY=bidready_minio
OBJECT_STORE_SECRET_KEY=bidready_minio_dev_pw
OBJECT_STORE_BUCKET=bidready-documents
OBJECT_STORE_REGION=me-central-1
# Only set when the API runs behind a proxy and the browser must
# download direct from the storage host.
OBJECT_STORE_PUBLIC_HOST=

# ============================================================
# LLM provider
#   LLM_PROVIDER=deepseek  — primary; needs DEEPSEEK_API_KEY
#   LLM_PROVIDER=ollama    — local fallback (docker-compose profile: optional-local-llm)
#   LLM_PROVIDER=mock      — deterministic, no network (tests / first-boot)
# ============================================================
LLM_PROVIDER=mock

# DeepSeek (https://api.deepseek.com — OpenAI-compatible)
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_HIGH_QUALITY_MODEL=deepseek-v4-pro
DEEPSEEK_TEMPERATURE=0.1
DEEPSEEK_MAX_TOKENS=8000
# USD per 1k tokens — used by LlmUsageService cost estimator.
DEEPSEEK_FLASH_INPUT_PER_1K=0.00014
DEEPSEEK_FLASH_OUTPUT_PER_1K=0.00028
DEEPSEEK_PRO_INPUT_PER_1K=0.0014
DEEPSEEK_PRO_OUTPUT_PER_1K=0.0028

# Ollama (optional local fallback)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=qwen2.5:7b-instruct
OLLAMA_TEMPERATURE=0.2
OLLAMA_MAX_TOKENS=8000

# Fail-closed daily caps enforced by BudgetGuardService.
LLM_DAILY_MAX_REQUESTS=1000
LLM_DAILY_MAX_COST_USD=10
LLM_MAX_TOKENS_PER_REQUEST=8000

# ============================================================
# Notifications (interface only for now; SMTP/Slack/WhatsApp in PRD work)
# ============================================================
NOTIFICATION_PROVIDER=console

# ============================================================
# Observability (docker-compose: prometheus, grafana)
# ============================================================
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001

# ============================================================
# Workflow (docker-compose: n8n)
# ============================================================
N8N_BASE_URL=http://localhost:5678
N8N_WEBHOOK_SECRET=dev_webhook_secret_change_me
