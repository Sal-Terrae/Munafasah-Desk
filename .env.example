# BidReady KSA — local development defaults.
# Copy to .env for local runs. These are NON-SECRET dev-only values.
# Never use these values outside local development.

# --- API ---
API_PORT=8080
NODE_ENV=development

# --- PostgreSQL ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=bidready
POSTGRES_USER=bidready
POSTGRES_PASSWORD=bidready_dev_pw

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Object storage (MinIO local) ---
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=bidready_minio
S3_SECRET_KEY=bidready_minio_dev_pw
S3_BUCKET=bidready-local

# --- LLM / OCR (provider abstraction; leave empty for mock/tests) ---
LLM_PROVIDER=mock
OPENAI_API_KEY=
OCR_PROVIDER=tesseract
